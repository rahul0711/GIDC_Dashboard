<?xml version="1.0" encoding="utf-8"?>
<!--
  LOGIN SCREEN — GIDC Notified Area Authority
  Theme: Deep navy authority + gold accent, clean card bottom sheet
  Font: sans-serif-condensed for labels, sans-serif-medium for headings
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
   >

    <!-- ───── HERO SECTION (top ~45%) ───── -->
    <LinearLayout
        android:id="@+id/llHero"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardLogin"
        android:background="#1A3A6E"
        app:layout_constraintVertical_chainStyle="spread">

        <!-- Top accent strip — Script India blue -->


        <!-- Logo on white card — same as splash -->
        <FrameLayout
            android:layout_width="240dp"
            android:layout_height="68dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:background="@drawable/splash_logo_card">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="210dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:contentDescription="GIDC Logo"
                android:src="@drawable/logo" />

        </FrameLayout>

        <!-- Authority Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.18"
            android:text="GIDC NOTIFIED AREA"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.18"
            android:text="AUTHORITY"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Blue divider — matches Script India accent -->
        <View
            android:layout_width="48dp"
            android:layout_height="2dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="#1565C0" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.20"
            android:text="VAPI, GUJARAT"
            android:textColor="#AABBD8"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Powered by — mirrors logo style, sits at bottom of hero -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Powered by  "
                android:textColor="#55FFFFFF"
                android:textSize="10sp"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCRIPT"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.16" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:background="#1565C0"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="INDIA"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.14" />

        </LinearLayout>

    </LinearLayout>

    <!-- ───── LOGIN CARD ───── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"

        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="32dp">

            <!-- Drag handle -->
            <View
                android:layout_width="36dp"
                android:layout_height="3dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"
                android:background="#E2E8F0" />

            <!-- Eyebrow label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.20"
                android:text="SECURE ACCESS"
                android:textColor="#C9A84C"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Heading -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="28dp"
                android:fontFamily="sans-serif-medium"
                android:text="Sign in to your account"
                android:textColor="#0D1B3E"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- USERNAME LABEL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.14"
                android:text="USERNAME"
                android:textColor="#8898AA"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Username field wrapper (border + icon) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/input_field_bg">

                <!-- Person icon -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="14dp"
                    android:contentDescription="Username icon"
                    android:src="@drawable/ic_person"
                    app:tint="#8898AA" />

                <EditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:fontFamily="sans-serif"
                    android:hint="Enter your username"
                    android:inputType="text"
                    android:paddingStart="48dp"
                    android:paddingEnd="14dp"
                    android:textColor="#0D1B3E"
                    android:textColorHint="#C4CFD8"
                    android:textSize="15sp" />
            </FrameLayout>

            <!-- PASSWORD LABEL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.14"
                android:text="PASSWORD"
                android:textColor="#8898AA"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Password field wrapper -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_field_bg">

                <!-- Lock icon -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="14dp"
                    android:contentDescription="Password icon"
                    android:src="@drawable/ic_lock"
                    app:tint="#8898AA" />
                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:fontFamily="sans-serif"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:paddingStart="48dp"
                    android:paddingEnd="48dp"
                    android:textColor="#0D1B3E"
                    android:textColorHint="#C4CFD8"
                    android:textSize="15sp" />

                <!-- Show/hide password toggle -->
                <ImageView
                    android:id="@+id/ivPasswordToggle"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="14dp"
                    android:contentDescription="Toggle password visibility"
                    android:src="@drawable/ic_visibility_off"
                    app:tint="#8898AA" />
            </FrameLayout>

            <!-- Forgot password -->
            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="28dp"
                android:fontFamily="sans-serif"
                android:text="Forgot password?"
                android:textColor="#0B3D91"
                android:textSize="13sp" />

            <!-- Sign In Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="20dp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.12"
                android:text="SIGN IN"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="#0B3D91"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_login"
                app:iconGravity="textEnd"
                app:iconTint="#FFFFFF"
                app:rippleColor="#1A5FD4" />

            <!-- Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="0.5dp"
                    android:layout_weight="1"
                    android:background="#E2E8F0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:fontFamily="sans-serif"
                    android:text="Created by Script India"
                    android:textColor="#B0BCC8"
                    android:textSize="11sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0.5dp"
                    android:layout_weight="1"
                    android:background="#E2E8F0" />

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>