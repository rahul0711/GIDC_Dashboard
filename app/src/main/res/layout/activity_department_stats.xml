<?xml version="1.0" encoding="utf-8"?>
<!--
  ╔══════════════════════════════════════════════════════════════════╗
  ║          DEPARTMENT STATS SCREEN — COMPLETE SINGLE FILE          ║
  ║  Sections: Complaint Status · Time Alerts                        ║
  ║  Agency role hides sectionTimeAlerts via Kotlin                  ║
  ╚══════════════════════════════════════════════════════════════════╝
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EEF2FB">

    <!-- ══════════════════════════════════════════ -->
    <!--               FIXED HEADER                 -->
    <!-- ══════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0A2E6E">

        <!-- Gold accent strip top -->
        <View
            android:id="@+id/headerAccent"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#F4C430"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/headerBody"
            android:layout_width="411dp"
            android:layout_height="197dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="44dp"
            android:paddingEnd="24dp"
            android:paddingBottom="28dp"
            android:background="@drawable/header_gradient"
            app:layout_constraintTop_toBottomOf="@id/headerAccent">

            <!-- Icon in frosted circle -->


            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:letterSpacing="0.01"
                android:text="Department Stats"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Gold LIVE badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="#F4C430"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:layout_marginEnd="7dp"
                    android:background="#0A2E6E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.12"
                    android:text="LIVE OVERVIEW"
                    android:textColor="#0A2E6E"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Bottom strip for page background bleed -->
        <View
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:background="#EEF2FB"
            app:layout_constraintTop_toBottomOf="@id/headerBody"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ══════════════════════════════════════════ -->
    <!--            SCROLLABLE CONTENT              -->
    <!-- ══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#EEF2FB"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="32dp">

            <!-- ─── Section Header: Complaint Status ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="14dp">
                <View
                    android:layout_width="4dp"
                    android:layout_height="20dp"
                    android:background="#0A2E6E"
                    android:layout_marginEnd="10dp" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Complaint Status"
                    android:textColor="#0A2E6E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All Departments"
                    android:textColor="#9AAAC4"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- ══ Row 1: NEW | IN PROCESS ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- NEW -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNew"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:strokeColor="#DCE6FF"
                    app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <FrameLayout android:layout_width="44dp" android:layout_height="44dp" android:background="#F0F4FF" android:layout_marginBottom="12dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/resource_new" android:layout_gravity="center" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NEW" android:textColor="#9AAAC4" android:textSize="10sp" android:letterSpacing="0.1" android:textStyle="bold" />
                        <TextView android:id="@+id/tvNewCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#0A2E6E" android:textSize="28sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp" />
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F4FF" android:layout_marginTop="10dp" android:layout_marginBottom="8dp" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View all" android:textColor="#0A2E6E" android:textSize="11sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" →" android:textColor="#F4C430" android:textSize="12sp" android:textStyle="bold" />
                        </LinearLayout>
                        <TextView android:id="@+id/tvNew" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- IN PROCESS -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardInProcess"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:strokeColor="#DCE6FF"
                    app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <FrameLayout android:layout_width="44dp" android:layout_height="44dp" android:background="#FFF8EC" android:layout_marginBottom="12dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/loading_arrow" android:layout_gravity="center" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IN PROCESS" android:textColor="#9AAAC4" android:textSize="10sp" android:letterSpacing="0.1" android:textStyle="bold" />
                        <TextView android:id="@+id/tvInProcessCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#0A2E6E" android:textSize="28sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp" />
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F4FF" android:layout_marginTop="10dp" android:layout_marginBottom="8dp" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View all" android:textColor="#0A2E6E" android:textSize="11sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" →" android:textColor="#F4C430" android:textSize="12sp" android:textStyle="bold" />
                        </LinearLayout>
                        <TextView android:id="@+id/tvInProcess" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ══ Row 2: HOLD | CANCELLED ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- HOLD -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:strokeColor="#DCE6FF"
                    app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <FrameLayout android:layout_width="44dp" android:layout_height="44dp" android:background="#FFF3E0" android:layout_marginBottom="12dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/hold" android:layout_gravity="center" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HOLD" android:textColor="#9AAAC4" android:textSize="10sp" android:letterSpacing="0.1" android:textStyle="bold" />
                        <TextView android:id="@+id/tvHoldCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#0A2E6E" android:textSize="28sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp" />
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F4FF" android:layout_marginTop="10dp" android:layout_marginBottom="8dp" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View all" android:textColor="#0A2E6E" android:textSize="11sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" →" android:textColor="#F4C430" android:textSize="12sp" android:textStyle="bold" />
                        </LinearLayout>
                        <TextView android:id="@+id/tvHold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CANCELLED -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:strokeColor="#DCE6FF"
                    app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <FrameLayout android:layout_width="44dp" android:layout_height="44dp" android:background="#FFEBEE" android:layout_marginBottom="12dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/close" android:layout_gravity="center" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CANCELLED" android:textColor="#9AAAC4" android:textSize="10sp" android:letterSpacing="0.1" android:textStyle="bold" />
                        <TextView android:id="@+id/tvCancelCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#0A2E6E" android:textSize="28sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp" />
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F4FF" android:layout_marginTop="10dp" android:layout_marginBottom="8dp" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View all" android:textColor="#0A2E6E" android:textSize="11sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" →" android:textColor="#F4C430" android:textSize="12sp" android:textStyle="bold" />
                        </LinearLayout>
                        <TextView android:id="@+id/tvCancel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ══ Row 3: RESOLVED | RE-LAUNCHED (optional visibility) ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- RESOLVED -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardResolved"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:strokeColor="#C8E6C9"
                    app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <FrameLayout android:layout_width="44dp" android:layout_height="44dp" android:background="#E8F5E9" android:layout_marginBottom="12dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/working" android:layout_gravity="center" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RESOLVED" android:textColor="#9AAAC4" android:textSize="10sp" android:letterSpacing="0.1" android:textStyle="bold" />
                        <TextView android:id="@+id/tvResolvedCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#2E7D32" android:textSize="28sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp" />
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8F5E9" android:layout_marginTop="10dp" android:layout_marginBottom="8dp" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View all" android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" →" android:textColor="#4CAF50" android:textSize="12sp" android:textStyle="bold" />
                        </LinearLayout>
                        <TextView android:id="@+id/tvResolved" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- RE-LAUNCHED -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardReLaunched"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:strokeColor="#DCE6FF"
                    app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <FrameLayout android:layout_width="44dp" android:layout_height="44dp" android:background="#E8EAF6" android:layout_marginBottom="12dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/reload__1_" android:layout_gravity="center" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RE-LAUNCH" android:textColor="#9AAAC4" android:textSize="10sp" android:letterSpacing="0.1" android:textStyle="bold" />
                        <TextView android:id="@+id/tvReLaunchedCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#3949AB" android:textSize="28sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp" />
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8EAF6" android:layout_marginTop="10dp" android:layout_marginBottom="8dp" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View all" android:textColor="#3949AB" android:textSize="11sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" →" android:textColor="#7986CB" android:textSize="12sp" android:textStyle="bold" />
                        </LinearLayout>
                        <TextView android:id="@+id/tvReLaunched" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ══ APPROVED — full-width navy accent card (optional visibility) ══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardApproved"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                app:cardBackgroundColor="#0A2E6E"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="18dp"
                    android:paddingBottom="18dp">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="#1AFFFFFF"
                        android:layout_marginEnd="18dp">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/checkmark"
                            android:alpha="0.9"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="APPROVED"
                            android:textColor="#7A9CC8"
                            android:textSize="10sp"
                            android:letterSpacing="0.12"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvApproved"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Gold pill CTA -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#F4C430"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View all" android:textColor="#0A2E6E" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" →" android:textColor="#0A2E6E" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!--  TIME ALERTS SECTION — hidden for Agency role via Kotlin  -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/sectionTimeAlerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <View android:layout_width="4dp" android:layout_height="20dp" android:background="#C62828" android:layout_marginEnd="10dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Time Alerts"
                        android:textColor="#C62828"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.03"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠ Attention Required"
                        android:textColor="#EF5350"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                </LinearLayout>

                <!-- ALERT COUNT | NOT RESOLVED IN TIME -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="32dp">

                    <!-- COMPLAINT ALERT -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardAlertCount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="3dp"
                        app:strokeColor="#FFCDD2"
                        app:strokeWidth="1.5dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <!-- Red top accent bar -->
                            <View android:layout_width="match_parent" android:layout_height="3dp" android:background="#EF5350" android:layout_marginBottom="14dp" />
                            <FrameLayout android:layout_width="44dp" android:layout_height="44dp" android:background="#FFEBEE" android:layout_marginBottom="12dp">
                                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/clock" android:layout_gravity="center" />
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ALERT" android:textColor="#9AAAC4" android:textSize="10sp" android:letterSpacing="0.1" android:textStyle="bold" />
                            <TextView android:id="@+id/tvAlertCountNum" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#C62828" android:textSize="28sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp" />
                            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FFEBEE" android:layout_marginTop="10dp" android:layout_marginBottom="8dp" />
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View all" android:textColor="#C62828" android:textSize="11sp" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" →" android:textColor="#EF5350" android:textSize="12sp" android:textStyle="bold" />
                            </LinearLayout>
                            <TextView android:id="@+id/tvAlertCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- NOT RESOLVED IN TIME -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardResolveCount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="3dp"
                        app:strokeColor="#C8E6C9"
                        app:strokeWidth="1.5dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <!-- Green top accent bar -->
                            <View android:layout_width="match_parent" android:layout_height="3dp" android:background="#2E7D32" android:layout_marginBottom="14dp" />
                            <FrameLayout android:layout_width="44dp" android:layout_height="44dp" android:background="#E8F5E9" android:layout_marginBottom="12dp">
                                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/restriction" android:layout_gravity="center" />
                            </FrameLayout>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="NOT RESOLVED" android:textColor="#9AAAC4" android:textSize="10sp" android:letterSpacing="0.1" android:textStyle="bold" />
                            <TextView android:id="@+id/tvResolveCountNum" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#2E7D32" android:textSize="28sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp" />
                            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8F5E9" android:layout_marginTop="10dp" android:layout_marginBottom="8dp" />
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View all" android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" →" android:textColor="#4CAF50" android:textSize="12sp" android:textStyle="bold" />
                            </LinearLayout>
                            <TextView android:id="@+id/tvResolveCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>
            <!-- END sectionTimeAlerts -->

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>