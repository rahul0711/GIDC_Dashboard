<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Small grey uppercase label -->
    <style name="LabelStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">#9E9E9E</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.10</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Bold readable value -->
    <style name="ValueStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">#1A1A2E</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Thin divider line -->
    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#F0F0F0</item>
        <item name="android:layout_marginTop">12dp</item>
    </style>

</resources>